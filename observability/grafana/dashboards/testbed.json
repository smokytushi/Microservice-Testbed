{
  "title": "Fault Tolerance Testbed",
  "uid": "ft-testbed-01",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-10m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Order Success Rate",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(order_requests_total{status='success'}[1m])) / sum(rate(order_requests_total[1m])) * 100",
        "legendFormat": "Success %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [
        { "color": "red", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 95 }
      ]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Circuit Breaker State",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "circuit_breaker_state", "legendFormat": "CB State" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF-OPEN", "color": "yellow" } } }
      ], "thresholds": { "steps": [{ "color": "green", "value": 0 }] }}}
    },
    {
      "id": 3, "type": "stat", "title": "Timeout Events",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(increase(order_timeout_total[5m]))", "legendFormat": "Timeouts (5m)" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        { "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
      ]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Bulkhead Rejections",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(increase(bulkhead_rejected_total[5m]))", "legendFormat": "Rejected (5m)" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        { "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
      ]}}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Request Rate by Status (Order Service)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(order_requests_total[30s])", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }},
      "options": { "tooltip": { "mode": "multi" }}
    },
    {
      "id": 6, "type": "timeseries", "title": "Latency P50 / P95 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(order_latency_seconds_bucket[30s])) * 1000", "legendFormat": "Order P50" },
        { "expr": "histogram_quantile(0.95, rate(order_latency_seconds_bucket[30s])) * 1000", "legendFormat": "Order P95" },
        { "expr": "histogram_quantile(0.50, rate(payment_latency_seconds_bucket[30s])) * 1000", "legendFormat": "Payment P50" },
        { "expr": "histogram_quantile(0.50, rate(inventory_latency_seconds_bucket[30s])) * 1000", "legendFormat": "Inventory P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }}
    },
    {
      "id": 7, "type": "timeseries", "title": "Circuit Breaker State Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{ "expr": "circuit_breaker_state", "legendFormat": "CB State (0=closed 1=open 2=half-open)" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 2 }}
    },
    {
      "id": 8, "type": "timeseries", "title": "Retry Attempts (Notification)",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "targets": [
        { "expr": "rate(notification_retries_total[30s])", "legendFormat": "Retries/s" },
        { "expr": "rate(notification_retry_exhausted_total[30s])", "legendFormat": "Exhausted/s" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Bulkhead Active Threads",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "targets": [{ "expr": "bulkhead_active_threads", "legendFormat": "{{pool}} pool" }],
      "fieldConfig": { "defaults": { "unit": "short" }}
    },
    {
      "id": 10, "type": "timeseries", "title": "Error Rate by Service",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        { "expr": "rate(order_requests_total{status!='success'}[30s])", "legendFormat": "Order - {{status}}" },
        { "expr": "rate(payment_requests_total{status!='success'}[30s])", "legendFormat": "Payment - {{status}}" },
        { "expr": "rate(inventory_requests_total{status!='success'}[30s])", "legendFormat": "Inventory - {{status}}" },
        { "expr": "rate(notification_requests_total{status!='success'}[30s])", "legendFormat": "Notify - {{status}}" }
      ]
    }
  ]
}
